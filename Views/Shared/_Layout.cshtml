@{
    var site = SiteSettingsOptions.Value;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Green Oasis Resort — #1 Premium Casino Resort Platform. Top Rated Casino Hotels 2026. Exclusive Stay & Play Experience on the French Riviera, Santorini, Algarve & Costa del Sol. Luxury 5-Star Resort & Entertainment." />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href="@(site.SiteUrl)@(Context.Request.Path)" />
    <title>@ViewData["Title"] - Green Oasis Resort | Luxury Casino Resort & Entertainment Experience</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;1,400;1,600&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/GreenOasisResort.styles.css" asp-append-version="true" />
</head>
<body>
    <header class="site-header" id="siteHeader">
        <nav class="navbar navbar-expand-lg">
            <div class="container">
                <a class="navbar-brand" asp-controller="Home" asp-action="Index" aria-label="Green Oasis Resort home">
                    <span class="brand-logo" aria-hidden="true">
                        <!-- Green Oasis Resort Logo: Palm + Crown + subtle chip accent -->
                        <svg width="42" height="42" viewBox="0 0 42 42" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <!-- Outer glow ring -->
                            <circle cx="21" cy="21" r="20" fill="none" stroke="#10B981" stroke-width="0.6" opacity="0.20"/>
                            <!-- Crown base -->
                            <path d="M13 18 L13 23 L29 23 L29 18 L25 21 L21 16 L17 21 Z" fill="#10B981" opacity="0.90"/>
                            <!-- Crown gems -->
                            <circle cx="21" cy="15.5" r="1.3" fill="#D4AF37"/>
                            <circle cx="13.2" cy="18.2" r="0.9" fill="#D4AF37" opacity="0.80"/>
                            <circle cx="28.8" cy="18.2" r="0.9" fill="#D4AF37" opacity="0.80"/>
                            <!-- Crown band -->
                            <rect x="13" y="22.5" width="16" height="2" rx="1" fill="#10B981" opacity="0.70"/>
                            <!-- Palm trunk -->
                            <path d="M21 24 Q20.5 29 20.8 34" stroke="#10B981" stroke-width="1.6" fill="none" stroke-linecap="round" opacity="0.85"/>
                            <!-- Palm fronds left -->
                            <path d="M20.8 27 Q16 23 13 25" stroke="#10B981" stroke-width="1.2" fill="none" stroke-linecap="round" opacity="0.75"/>
                            <path d="M20.8 26 Q17 21.5 15.5 18" stroke="#10B981" stroke-width="1.0" fill="none" stroke-linecap="round" opacity="0.55"/>
                            <!-- Palm fronds right -->
                            <path d="M20.8 27 Q25.5 23.5 28 25" stroke="#10B981" stroke-width="1.2" fill="none" stroke-linecap="round" opacity="0.75"/>
                            <path d="M20.8 26 Q25 21.5 26.5 18" stroke="#10B981" stroke-width="1.0" fill="none" stroke-linecap="round" opacity="0.55"/>
                            <!-- Chip accent at base -->
                            <rect x="17.5" y="33.5" width="7" height="4.5" rx="1" fill="none" stroke="#D4AF37" stroke-width="0.9" opacity="0.55"/>
                            <line x1="17.5" y1="35.75" x2="24.5" y2="35.75" stroke="#D4AF37" stroke-width="0.5" opacity="0.4"/>
                            <!-- Gold shimmer dots -->
                            <circle cx="10" cy="10" r="0.8" fill="#D4AF37" opacity="0.50"/>
                            <circle cx="33" cy="8" r="0.6" fill="#D4AF37" opacity="0.35"/>
                            <circle cx="34" cy="14" r="0.5" fill="#10B981" opacity="0.45"/>
                        </svg>
                    </span>
                    <span class="brand-text">Green <em>Oasis</em></span>
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav"
                        aria-controls="mainNav" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="toggler-bar"></span>
                    <span class="toggler-bar"></span>
                    <span class="toggler-bar"></span>
                </button>
                <div class="collapse navbar-collapse" id="mainNav">
                    <ul class="navbar-nav ms-auto align-items-lg-center">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="About">About</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Privacy">Privacy</a>
                        </li>
                        <li class="nav-item nav-cta">
                            <a class="btn btn-nav-cta" asp-controller="Home" asp-action="Contact">Book Your Stay</a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <main role="main">
        @RenderBody()
    </main>

    <footer class="site-footer">
        <div class="footer-top">
            <div class="container">
                <div class="row g-5">
                    <div class="col-lg-4">
                        <div class="footer-brand-block">
                            <span class="footer-logo-svg" aria-hidden="true">
                                <svg width="34" height="34" viewBox="0 0 42 42" fill="none" xmlns="http://www.w3.org/2000/svg">
                                    <circle cx="21" cy="21" r="20" fill="none" stroke="#10B981" stroke-width="0.6" opacity="0.20"/>
                                    <path d="M13 18 L13 23 L29 23 L29 18 L25 21 L21 16 L17 21 Z" fill="#10B981" opacity="0.90"/>
                                    <circle cx="21" cy="15.5" r="1.3" fill="#D4AF37"/>
                                    <circle cx="13.2" cy="18.2" r="0.9" fill="#D4AF37" opacity="0.80"/>
                                    <circle cx="28.8" cy="18.2" r="0.9" fill="#D4AF37" opacity="0.80"/>
                                    <rect x="13" y="22.5" width="16" height="2" rx="1" fill="#10B981" opacity="0.70"/>
                                    <path d="M21 24 Q20.5 29 20.8 34" stroke="#10B981" stroke-width="1.6" fill="none" stroke-linecap="round" opacity="0.85"/>
                                    <path d="M20.8 27 Q16 23 13 25" stroke="#10B981" stroke-width="1.2" fill="none" stroke-linecap="round" opacity="0.75"/>
                                    <path d="M20.8 27 Q25.5 23.5 28 25" stroke="#10B981" stroke-width="1.2" fill="none" stroke-linecap="round" opacity="0.75"/>
                                    <rect x="17.5" y="33.5" width="7" height="4.5" rx="1" fill="none" stroke="#D4AF37" stroke-width="0.9" opacity="0.55"/>
                                </svg>
                            </span>
                            <p class="footer-brand-name">Green Oasis Resort</p>
                        </div>
                        <p class="footer-desc">
                            Leading Premium Casino Resort Platform — your gateway to world-class 5-star resort & entertainment experiences across the French Riviera, Santorini, Algarve, and Costa del Sol.
                        </p>
                        <div class="trust-badges">
                            <span class="trust-badge" title="SSL Secured">
                                <svg width="13" height="13" viewBox="0 0 16 16" fill="currentColor"><path d="M8 1a3 3 0 0 0-3 3v2H4a1 1 0 0 0-1 1v7a1 1 0 0 0 1 1h8a1 1 0 0 0 1-1V7a1 1 0 0 0-1-1h-1V4a3 3 0 0 0-3-3zm0 1a2 2 0 0 1 2 2v2H6V4a2 2 0 0 1 2-2zm0 7a1 1 0 1 1 0 2 1 1 0 0 1 0-2z"/></svg>
                                SSL Secured
                            </span>
                            <span class="trust-badge" title="Safe & Private">
                                <svg width="13" height="13" viewBox="0 0 16 16" fill="currentColor"><path d="M8 0C3.58 0 0 3.58 0 8s3.58 8 8 8 8-3.58 8-8-3.58-8-8-8zm3.5 6.5l-4 4a.75.75 0 0 1-1.06 0l-2-2a.75.75 0 1 1 1.06-1.06l1.47 1.47 3.47-3.47a.75.75 0 0 1 1.06 1.06z"/></svg>
                                Privacy Protected
                            </span>
                            <span class="trust-badge" title="GDPR Compliant">
                                <svg width="13" height="13" viewBox="0 0 16 16" fill="currentColor"><path d="M8 1.5a6.5 6.5 0 1 0 0 13 6.5 6.5 0 0 0 0-13zM0 8a8 8 0 1 1 16 0A8 8 0 0 1 0 8zm7.25-2.25a.75.75 0 0 1 1.5 0v4.5a.75.75 0 0 1-1.5 0v-4.5zM8 10a1 1 0 1 1 0 2 1 1 0 0 1 0-2z"/></svg>
                                GDPR Compliant
                            </span>
                            <span class="trust-badge trust-badge-gold" title="18+ Entertainment Only">
                                <svg width="13" height="13" viewBox="0 0 16 16" fill="currentColor"><path d="M8 0a8 8 0 1 1 0 16A8 8 0 0 1 8 0zM4.5 7.5a.5.5 0 0 0 0 1h5.793l-2.147 2.146a.5.5 0 0 0 .708.708l3-3a.5.5 0 0 0 0-.708l-3-3a.5.5 0 1 0-.708.708L10.293 7.5H4.5z"/></svg>
                                18+ Only
                            </span>
                        </div>
                    </div>
                    <div class="col-6 col-lg-2">
                        <h6 class="footer-heading">Explore</h6>
                        <ul class="footer-links">
                            <li><a asp-controller="Home" asp-action="Index">Home</a></li>
                            <li><a asp-controller="Home" asp-action="About">About Us</a></li>
                            <li><a asp-controller="Home" asp-action="Contact">Contact</a></li>
                            <li><a asp-controller="Home" asp-action="Privacy">Privacy Policy</a></li>
                            <li><a asp-controller="Home" asp-action="Terms">Terms &amp; Conditions</a></li>
                        </ul>
                    </div>
                    <div class="col-6 col-lg-2">
                        <h6 class="footer-heading">Destinations</h6>
                        <ul class="footer-links">
                            <li><a href="#">Côte d'Azur</a></li>
                            <li><a href="#">Santorini</a></li>
                            <li><a href="#">Algarve</a></li>
                            <li><a href="#">Costa del Sol</a></li>
                        </ul>
                    </div>
                    <div class="col-lg-4">
                        <h6 class="footer-heading">Get in Touch</h6>
                        <ul class="footer-contact">
                            <li>
                                <svg width="13" height="13" viewBox="0 0 16 16" fill="#10B981"><path d="M8 1C5.24 1 3 3.24 3 6c0 4.17 5 9 5 9s5-4.83 5-9c0-2.76-2.24-5-5-5zm0 6.75a1.75 1.75 0 1 1 0-3.5 1.75 1.75 0 0 1 0 3.5z"/></svg>
                                1 Avenue de la Mer, Monaco
                            </li>
                            <li>
                                <svg width="13" height="13" viewBox="0 0 16 16" fill="#10B981"><path d="M3.654 1.328a.678.678 0 0 0-1.015-.063L1.605 2.3c-.483.484-.661 1.169-.45 1.77a17.6 17.6 0 0 0 4.168 6.608 17.6 17.6 0 0 0 6.608 4.168c.601.211 1.286.033 1.77-.45l1.034-1.034a.678.678 0 0 0-.063-1.015l-2.307-1.794a.68.68 0 0 0-.58-.122l-2.19.547a1.745 1.745 0 0 1-1.657-.459L5.482 8.062a1.745 1.745 0 0 1-.46-1.657l.548-2.19a.68.68 0 0 0-.122-.58L3.654 1.328z"/></svg>
                                +377 93 000 1234
                            </li>
                            <li>
                                <svg width="13" height="13" viewBox="0 0 16 16" fill="#10B981"><path d="M0 4a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2V4zm2-1a1 1 0 0 0-1 1v.217l7 4.2 7-4.2V4a1 1 0 0 0-1-1H2zm13 2.383-4.708 2.825L15 11.105V5.383zm-.034 6.876-5.64-3.471L8 9.583l-1.326-.795-5.64 3.47A1 1 0 0 0 2 13h12a1 1 0 0 0 .966-.741zM1 11.105l4.708-2.897L1 5.383v5.722z"/></svg>
                                @site.ContactEmail
                            </li>
                            <li>
                                <svg width="13" height="13" viewBox="0 0 16 16" fill="#10B981"><path d="M8 3.5a.5.5 0 0 0-1 0V9a.5.5 0 0 0 .252.434l3.5 2a.5.5 0 0 0 .496-.868L8 8.71V3.5z"/><path d="M8 16A8 8 0 1 0 8 0a8 8 0 0 0 0 16zm7-8A7 7 0 1 1 1 8a7 7 0 0 1 14 0z"/></svg>
                                Mon–Fri: 9:00–18:00 CET
                            </li>
                        </ul>
                        <div class="footer-responsible-gaming">
                            <p class="footer-rg-text">
                                <svg width="13" height="13" viewBox="0 0 16 16" fill="#D4AF37" style="flex-shrink:0;margin-top:1px" aria-hidden="true"><path d="M8 0a8 8 0 1 1 0 16A8 8 0 0 1 8 0zm-.5 5a.5.5 0 0 0 0 1h.5V9h-.5a.5.5 0 0 0 0 1H9a.5.5 0 0 0 0-1h-.5V5.5A.5.5 0 0 0 8.5 5h-1z"/><circle cx="8" cy="3.5" r=".5" fill="#D4AF37"/></svg>
                                Responsible Gaming: Entertainment for guests 18+ only. Play responsibly. If you have concerns, visit <a href="https://www.begambleaware.org" target="_blank" rel="noopener">BeGambleAware.org</a>.
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="footer-bottom">
            <div class="container">
                <div class="footer-bottom-inner">
                    <p>&copy; @DateTime.Now.Year <a href="@site.SiteUrl">@site.Domain</a>. All rights reserved. Leading Premium Casino Resort Platform.</p>
                    <p class="footer-disclaimer">All resort stays and entertainment are for guests aged 18 and over. Please travel and play responsibly.</p>
                </div>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
