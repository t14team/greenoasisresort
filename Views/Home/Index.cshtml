@model List<GreenOasisResort.Models.HotelCard>
@{
    ViewData["Title"] = "Home | #1 Premium Casino Resort Platform — Top Rated Casino Hotels 2026";
    var featured = Model.First();
    var others = Model.Skip(1).ToList();
}

<section class="hero hero-image" style="background-image: url('/images/hero.jpg');" aria-label="Hero — Green Oasis Casino Resort">
    <div class="hero-overlay" aria-hidden="true"></div>
    <div class="container hero-content">
        <span class="hero-badge" role="text">
            <svg width="12" height="12" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true"><path d="M3.612 15.443c-.386.198-.824-.149-.746-.592l.83-4.73L.173 6.765c-.329-.314-.158-.888.283-.95l4.898-.696L7.538.792c.197-.39.73-.39.927 0l2.184 4.327 4.898.696c.441.062.612.636.282.95l-3.522 3.356.83 4.73c.078.443-.36.79-.746.592L8 13.187l-4.389 2.256z"/></svg>
            Top Rated Casino Resort Platform · 2026
        </span>
        <h1>Where <em>Luxury</em> Meets<br /><span class="gold-word">Entertainment</span></h1>
        <p class="lead">
            Experience the world's most exclusive Casino Resort destinations — from sun-kissed shores of the Côte d'Azur
            to the legendary clifftop villas of Santorini. #1 Premium Casino Resort Platform, trusted by discerning guests worldwide.
        </p>
        <div class="hero-actions">
            <a class="btn btn-accent" asp-action="Contact">
                <span>Book Your Stay</span>
                <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true"><path fill-rule="evenodd" d="M1 8a.5.5 0 0 1 .5-.5h11.793l-3.147-3.146a.5.5 0 0 1 .708-.708l4 4a.5.5 0 0 1 0 .708l-4 4a.5.5 0 0 1-.708-.708L13.293 8.5H1.5A.5.5 0 0 1 1 8z"/></svg>
            </a>
            <a class="btn btn-outline-light" asp-action="About">Explore Resort</a>
        </div>
        <p class="hero-microcopy">Luxury experience in seconds · Seamless booking, zero hassle · 18+ Entertainment</p>
        <div class="destinations-strip" role="list" aria-label="Featured destinations">
            <div class="destination-pill" role="listitem"><strong>Côte d'Azur</strong> Casino estates</div>
            <div class="destination-pill" role="listitem"><strong>Santorini</strong> Resort villas</div>
            <div class="destination-pill" role="listitem"><strong>Algarve</strong> Leisure retreats</div>
            <div class="destination-pill" role="listitem"><strong>Costa del Sol</strong> Grand resorts</div>
        </div>
    </div>
    <div class="hero-scroll-indicator" aria-hidden="true">
        <span></span>
    </div>
</section>

<!-- Casino Resort Experience Strip -->
<div class="experience-strip" aria-label="Resort entertainment features">
    <div class="container">
        <div class="experience-items">
            <div class="experience-item">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><rect x="2" y="2" width="20" height="20" rx="4"/><path d="M7 7h.01M17 7h.01M12 12h.01M7 17h.01M17 17h.01"/></svg>
                Premium Gaming Lounge
            </div>
            <div class="experience-dot" aria-hidden="true"></div>
            <div class="experience-item">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                5-Star Luxury Suites
            </div>
            <div class="experience-dot" aria-hidden="true"></div>
            <div class="experience-item">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/></svg>
                Live Entertainment
            </div>
            <div class="experience-dot" aria-hidden="true"></div>
            <div class="experience-item">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><path d="M18.364 5.636a9 9 0 1 1-12.728 0M12 3v9"/></svg>
                Signature Spa & Wellness
            </div>
            <div class="experience-dot" aria-hidden="true"></div>
            <div class="experience-item">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><path d="M3 11l19-9-9 19-2-8-8-2z"/></svg>
                Michelin-Star Dining
            </div>
        </div>
    </div>
</div>

<section class="stats-strip" aria-label="Platform highlights">
    <div class="container">
        <div class="stats-row">
            <div class="stat-item">
                <span class="stat-number">500+</span>
                <span class="stat-label">Luxury Properties</span>
            </div>
            <div class="stat-divider" aria-hidden="true"></div>
            <div class="stat-item">
                <span class="stat-number">98%</span>
                <span class="stat-label">Guest Satisfaction</span>
            </div>
            <div class="stat-divider" aria-hidden="true"></div>
            <div class="stat-item">
                <span class="stat-number gold">4.9★</span>
                <span class="stat-label">Average Rating 2026</span>
            </div>
            <div class="stat-divider" aria-hidden="true"></div>
            <div class="stat-item">
                <span class="stat-number">12+</span>
                <span class="stat-label">Destination Countries</span>
            </div>
        </div>
    </div>
</section>

<section class="section" aria-labelledby="featured-heading">
    <div class="container">
        <div class="section-header">
            <span class="section-label">Editor's Selection</span>
            <h2 id="featured-heading">Our Top Pick — Top Rated Casino Hotels 2026</h2>
            <p class="section-intro">Handpicked for unrivalled location, signature entertainment, and the complete luxury casino resort experience our VIP guests return to year after year.</p>
        </div>

        <article class="resort-featured" aria-label="@featured.Name — featured casino resort">
            <div class="resort-featured-image">
                <img src="@featured.ImageUrl" alt="@featured.Name luxury casino resort — @featured.Location" loading="lazy" />
                <div class="featured-image-overlay" aria-hidden="true"></div>
            </div>
            <div class="resort-featured-body">
                <span class="resort-meta">
                    <svg width="12" height="12" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true"><path d="M8 16s6-5.686 6-10A6 6 0 0 0 2 6c0 4.314 6 10 6 10zm0-7a3 3 0 1 1 0-6 3 3 0 0 1 0 6z"/></svg>
                    @featured.Location
                </span>
                <h3>@featured.Name</h3>
                <p>@featured.Description</p>
                <div class="amenity-tags" role="list" aria-label="Amenities">
                    @foreach (var amenity in featured.Amenities)
                    {
                        <span class="amenity-tag" role="listitem">@amenity</span>
                    }
                </div>
                <div class="featured-cta-group">
                    <a class="btn btn-accent mt-3" asp-action="Contact">
                        Start Your Experience
                        <svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true"><path fill-rule="evenodd" d="M1 8a.5.5 0 0 1 .5-.5h11.793l-3.147-3.146a.5.5 0 0 1 .708-.708l4 4a.5.5 0 0 1 0 .708l-4 4a.5.5 0 0 1-.708-.708L13.293 8.5H1.5A.5.5 0 0 1 1 8z"/></svg>
                    </a>
                    <span class="featured-trust-note">
                        <svg width="12" height="12" viewBox="0 0 16 16" fill="#10B981" aria-hidden="true"><path d="M8 1a3 3 0 0 0-3 3v2H4a1 1 0 0 0-1 1v7a1 1 0 0 0 1 1h8a1 1 0 0 0 1-1V7a1 1 0 0 0-1-1h-1V4a3 3 0 0 0-3-3z"/></svg>
                        Secure &amp; Confidential Inquiry
                    </span>
                </div>
            </div>
        </article>
    </div>
</section>

<section class="section section-alt" aria-labelledby="destinations-heading">
    <div class="container">
        <div class="section-header">
            <span class="section-label">Premium Resort Destinations</span>
            <h2 id="destinations-heading">Best Resort &amp; Entertainment Experience</h2>
            <p class="section-intro">Each property is selected for its exceptional setting, five-star service, and exclusive casino resort amenities — the pinnacle of Stay &amp; Play luxury.</p>
        </div>

        <div class="resort-grid" role="list" aria-label="Casino resort collection">
            @foreach (var hotel in others)
            {
                <article class="resort-card" role="listitem" aria-label="@hotel.Name">
                    <div class="resort-card-image">
                        <img src="@hotel.ImageUrl" alt="@hotel.Name luxury casino resort — @hotel.Location" loading="lazy" />
                        <div class="card-image-overlay" aria-hidden="true"></div>
                    </div>
                    <div class="resort-card-body">
                        <span class="resort-meta">
                            <svg width="11" height="11" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true"><path d="M8 16s6-5.686 6-10A6 6 0 0 0 2 6c0 4.314 6 10 6 10zm0-7a3 3 0 1 1 0-6 3 3 0 0 1 0 6z"/></svg>
                            @hotel.Location
                        </span>
                        <h3>@hotel.Name</h3>
                        <p>@hotel.Description</p>
                        <div class="amenity-tags" role="list" aria-label="Amenities">
                            @foreach (var amenity in hotel.Amenities)
                            {
                                <span class="amenity-tag" role="listitem">@amenity</span>
                            }
                        </div>
                    </div>
                </article>
            }
        </div>
    </div>
</section>

<section class="section" aria-labelledby="why-heading">
    <div class="container">
        <div class="section-header">
            <span class="section-label">Why Green Oasis</span>
            <h2 id="why-heading">Leading Luxury Casino Resort — What Sets Us Apart</h2>
            <p class="section-intro">We believe luxury resort entertainment should be effortless, exclusive, and tailored entirely to you. Every stay is a VIP experience.</p>
        </div>
        <div class="info-grid" role="list" aria-label="Resort features">
            <div class="info-block" role="listitem">
                <div class="info-icon" aria-hidden="true">
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                </div>
                <h3>Prime Resort Locations</h3>
                <p>Exclusive beachfront casino resorts on the French Riviera, Aegean cliffs, Atlantic coasts, and Mediterranean shores — where the VIP lifestyle comes naturally.</p>
            </div>
            <div class="info-block" role="listitem">
                <div class="info-icon" aria-hidden="true">
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="2" width="20" height="20" rx="4"/><path d="M7 7h.01M17 7h.01M12 12h.01M7 17h.01M17 17h.01"/></svg>
                </div>
                <h3>World-Class Entertainment</h3>
                <p>Premium gaming lounges, live shows, and leisure facilities — each property delivers an immersive, refined entertainment experience within a 5-star resort setting.</p>
            </div>
            <div class="info-block" role="listitem">
                <div class="info-icon" aria-hidden="true">
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/></svg>
                </div>
                <h3>Complete VIP Comfort</h3>
                <p>Signature spa retreats, infinity pools, Michelin-starred dining, and private beach clubs — everything for the ultimate luxury casino resort stay is already included.</p>
            </div>
            <div class="info-block" role="listitem">
                <div class="info-icon" aria-hidden="true">
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
                </div>
                <h3>Licensed &amp; Verified</h3>
                <p>All properties are personally vetted, GDPR-compliant, and featured only after meeting our rigorous quality, safety, and responsible entertainment standards.</p>
            </div>
        </div>
    </div>
</section>

<section class="testimonials-section section" aria-labelledby="testimonials-heading">
    <div class="container">
        <div class="section-header text-center-header">
            <span class="section-label">VIP Guest Stories</span>
            <h2 id="testimonials-heading">Trusted by Luxury Resort Guests Worldwide</h2>
        </div>
        <div class="testimonials-grid" role="list" aria-label="Guest testimonials">
            <blockquote class="testimonial-card" role="listitem">
                <div class="testimonial-stars" aria-label="5 star rating">★★★★★</div>
                <p>"An extraordinary stay at the Grand Palms Estate. The gaming lounge, private beach, impeccable service, and evening resort views made it a once-in-a-lifetime experience. Already planning our return."</p>
