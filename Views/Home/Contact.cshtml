@model GreenOasisResort.Models.ContactViewModel
@{
    ViewData["Title"] = "Contact Us | Green Oasis Resort — Book Your Luxury Casino Resort Stay";
    var site = SiteSettingsOptions.Value;
}

<section class="page-header page-header-image" style="background-image: url('/images/hero.jpg');" aria-label="Contact Green Oasis Casino Resort">
    <div class="page-header-overlay" aria-hidden="true"></div>
    <div class="container page-header-content">
        <span class="hero-badge">Get in Touch</span>
        <h1>Contact Our Concierge Team</h1>
        <p>Ready to plan your dream casino resort stay? Our VIP specialists reply within one business day.</p>
    </div>
</section>

<section class="content-section" aria-labelledby="contact-heading">
    <div class="container">
        <div class="contact-grid">
            <div class="contact-info-card">
                <h2 id="contact-heading" class="contact-card-title">Resort Concierge</h2>
                <p class="contact-intro">Our dedicated VIP hospitality team is here to help you find the perfect luxury casino resort experience — curated exclusively for you.</p>

                <div class="contact-detail">
                    <div class="contact-detail-icon" aria-hidden="true">
                        <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor"><path d="M8 1C5.24 1 3 3.24 3 6c0 4.17 5 9 5 9s5-4.83 5-9c0-2.76-2.24-5-5-5zm0 6.75a1.75 1.75 0 1 1 0-3.5 1.75 1.75 0 0 1 0 3.5z"/></svg>
                    </div>
                    <div>
                        <h5>Address</h5>
                        <p>1 Avenue de la Mer<br />Monaco, MC 98000</p>
                    </div>
                </div>

                <div class="contact-detail">
                    <div class="contact-detail-icon" aria-hidden="true">
                        <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor"><path d="M3.654 1.328a.678.678 0 0 0-1.015-.063L1.605 2.3c-.483.484-.661 1.169-.45 1.77a17.6 17.6 0 0 0 4.168 6.608 17.6 17.6 0 0 0 6.608 4.168c.601.211 1.286.033 1.77-.45l1.034-1.034a.678.678 0 0 0-.063-1.015l-2.307-1.794a.68.68 0 0 0-.58-.122l-2.19.547a1.745 1.745 0 0 1-1.657-.459L5.482 8.062a1.745 1.745 0 0 1-.46-1.657l.548-2.19a.68.68 0 0 0-.122-.58L3.654 1.328z"/></svg>
                    </div>
                    <div>
                        <h5>Phone</h5>
                        <p>+377 93 000 1234</p>
                    </div>
                </div>

                <div class="contact-detail">
                    <div class="contact-detail-icon" aria-hidden="true">
                        <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor"><path d="M0 4a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2V4zm2-1a1 1 0 0 0-1 1v.217l7 4.2 7-4.2V4a1 1 0 0 0-1-1H2zm13 2.383-4.708 2.825L15 11.105V5.383zm-.034 6.876-5.64-3.471L8 9.583l-1.326-.795-5.64 3.47A1 1 0 0 0 2 13h12a1 1 0 0 0 .966-.741zM1 11.105l4.708-2.897L1 5.383v5.722z"/></svg>
                    </div>
                    <div>
                        <h5>Email</h5>
                        <p>@site.ContactEmail</p>
                    </div>
                </div>

                <div class="contact-detail">
                    <div class="contact-detail-icon" aria-hidden="true">
                        <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor"><path d="M8 3.5a.5.5 0 0 0-1 0V9a.5.5 0 0 0 .252.434l3.5 2a.5.5 0 0 0 .496-.868L8 8.71V3.5z"/><path d="M8 16A8 8 0 1 0 8 0a8 8 0 0 0 0 16zm7-8A7 7 0 1 1 1 8a7 7 0 0 1 14 0z"/></svg>
                    </div>
                    <div>
                        <h5>Hours</h5>
                        <p>Monday – Friday: 9:00 – 18:00 CET<br />Saturday – Sunday: Closed</p>
                    </div>
                </div>

                <div class="contact-trust-strip">
                    <span class="trust-badge">
                        <svg width="12" height="12" viewBox="0 0 16 16" fill="currentColor"><path d="M8 1a3 3 0 0 0-3 3v2H4a1 1 0 0 0-1 1v7a1 1 0 0 0 1 1h8a1 1 0 0 0 1-1V7a1 1 0 0 0-1-1h-1V4a3 3 0 0 0-3-3zm0 1a2 2 0 0 1 2 2v2H6V4a2 2 0 0 1 2-2zm0 7a1 1 0 1 1 0 2 1 1 0 0 1 0-2z"/></svg>
                        SSL Secured
                    </span>
                    <span class="trust-badge">
                        <svg width="12" height="12" viewBox="0 0 16 16" fill="currentColor"><path d="M8 0C3.58 0 0 3.58 0 8s3.58 8 8 8 8-3.58 8-8-3.58-8-8-8zm3.5 6.5l-4 4a.75.75 0 0 1-1.06 0l-2-2a.75.75 0 1 1 1.06-1.06l1.47 1.47 3.47-3.47a.75.75 0 0 1 1.06 1.06z"/></svg>
                        GDPR Compliant
                    </span>
                    <span class="trust-badge trust-badge-gold">
                        <svg width="12" height="12" viewBox="0 0 16 16" fill="currentColor"><path d="M8 0a8 8 0 1 1 0 16A8 8 0 0 1 8 0zM4.5 7.5a.5.5 0 0 0 0 1h5.793l-2.147 2.146a.5.5 0 0 0 .708.708l3-3a.5.5 0 0 0 0-.708l-3-3a.5.5 0 1 0-.708.708L10.293 7.5H4.5z"/></svg>
                        18+ Only
                    </span>
                </div>
            </div>

            <div class="contact-form-card">
                <h3>Send a Message</h3>
                <p class="contact-form-intro">Tell us about your ideal casino resort stay and we'll personally curate the perfect luxury experience for you.</p>

                @if (TempData["Success"] != null)
                {
                    <div class="alert-success-custom" role="alert">
                        <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true"><path d="M8 0C3.58 0 0 3.58 0 8s3.58 8 8 8 8-3.58 8-8-3.58-8-8-8zm3.5 6.5l-4 4a.75.75 0 0 1-1.06 0l-2-2a.75.75 0 1 1 1.06-1.06l1.47 1.47 3.47-3.47a.75.75 0 0 1 1.06 1.06z"/></svg>
                        Thank you — your message has been received. Our VIP concierge team will respond within one business day.
                    </div>
                }

                <form asp-action="Contact" method="post" novalidate>
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="form-group">
                        <label asp-for="Name" class="form-label">Full Name</label>
                        <input asp-for="Name" class="form-control" placeholder="Your full name" autocomplete="name" />
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="Email" class="form-label">Email Address</label>
                        <input asp-for="Email" class="form-control" placeholder="you@example.com" autocomplete="email" />
                        <span asp-validation-for="Email" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="Subject" class="form-label">Subject</label>
                        <input asp-for="Subject" class="form-control" placeholder="Casino resort enquiry or booking request" />
                        <span asp-validation-for="Subject" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="Message" class="form-label">Message</label>
                        <textarea asp-for="Message" class="form-control" placeholder="Tell us your preferred destination, travel dates, entertainment preferences, and any special requirements…"></textarea>
                        <span asp-validation-for="Message" class="text-danger"></span>
                    </div>

                    <button type="submit" class="btn btn-accent btn-submit w-100">
                        Send Message
                        <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true"><path d="M15.854.146a.5.5 0 0 1 .11.54l-5.819 14.547a.75.75 0 0 1-1.329.124l-3.178-4.995L.643 7.184a.75.75 0 0 1 .124-1.33L15.314.037a.5.5 0 0 1 .54.11z"/></svg>
                    </button>
                    <p class="form-privacy-note">
                        <svg width="11" height="11" viewBox="0 0 16 16" fill="#10B981" aria-hidden="true"><path d="M8 1a3 3 0 0 0-3 3v2H4a1 1 0 0 0-1 1v7a1 1 0 0 0 1 1h8a1 1 0 0 0 1-1V7a1 1 0 0 0-1-1h-1V4a3 3 0 0 0-3-3z"/></svg>
                        Your information is protected under our <a asp-action="Privacy">Privacy Policy</a>. We never share your data. Casino resort entertainment for 18+ only.
                    </p>
                </form>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
